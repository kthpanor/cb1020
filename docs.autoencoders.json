a narrow hidden layer acting as the bottleneck. We build it with ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"skWxKWIDjI"},{"type":"inlineCode","value":"MLPRegressor","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"J3fHJ3Ljry"},{"type":"text","value":", predicting the input from itself.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"cchahtO80w"}],"key":"BhuAx4mkNG"}],"key":"Z3WdkqBmBX"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"bottleneck_size = 8\n\nautoencoder = sklearn.neural_network.MLPRegressor(\n    hidden_layer_sizes=(32, bottleneck_size, 32),\n    activation=\"relu\",\n    solver=\"adam\",\n    max_iter=1000,\n    random_state=0,\n)\n","key":"GNXLm1UdQy"},{"type":"outputs","id":"VoFW1kvK412kK8Q7h0slM","children":[],"key":"pq8z2TVGLZ"}],"key":"mRjYRMqec1"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"The hidden layer sizes ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"MOh94QQeS7"},{"type":"inlineCode","value":"(32, 8, 32)","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ErCQCt4zcC"},{"type":"text","value":" describe an encoder (64 -> 32 -> 8) and a decoder (8 -> 32 -> 64) sharing the same network, with the 8-unit middle layer as the bottleneck — a much stronger compression than the 64-dimensional input.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"B6UddTxDCa"}],"key":"IsPuygNH6w"}],"key":"WxvStarPAo"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Model training","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":