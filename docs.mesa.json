an integer acting as a ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"P13jXPBDgk"},{"type":"inlineCode","value":"unique_id","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"YtNVEgZyEg"},{"type":"text","value":".","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"JBFFONuwDD"}],"key":"sCsPE19ZWX"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"The agents can have attributes and methods. One or more methods may be intended to be called when time steps are taken in the model. We here implement the ","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"LmjHtW28y0"},{"type":"inlineCode","value":"step()","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"CjOgJFuQxb"},{"type":"text","value":" method for that purpose.","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"KrfAlZQkQ8"}],"key":"ykAOwVmULr"}],"key":"BDgYNPiWsU"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"class Predator(mesa.Agent):\n\n    def __init__(self, model, age=0, strength=100):\n        super().__init__(model)  # parent class initialization\n\n        self.type = \"predator\"\n\n        self.age = age\n        self.strength = strength\n\n    def step(self):\n        self.age += 1\n        self.strength -= 10\n        print(f\"agent: {self.unique_id}, age: {self.age}, strength: {self.strength}\")","key":"cviYTPQe1r"},{"type":"outputs","id":"_Sw5QhcmHdJX9Dmvka4Hu","children":[],"key":"kdjgQSkqqw"}],"key":"eSjrXusUwB"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"class Prey(mesa.Agent):\n\n    def __init__(self, model, age=0, food_value=50):\n        super().__init__(model)  # parent class initialization\n\n        self.type = \"prey\"\n\n        self.age = age\n        self.food_value = food_value\n\n    def step(self):\n        self.age += 1\n        self.food_value += 1\n        print(\n            f\"agent: {self.unique_id}, age: {self.age}, food value: {self.food_value}\"\n        )","key":"IE5m9q0g1S"},{"type":"outputs","id":"t73sioKqt4dHpigWdcEAw","children":[],"key":"F4TtMmw2rw"}],"key":"SDXGeGmrA8"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Model","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"hiKpglmelH"}],"identifier":"model","label":"Model","html_id":"model","implicit":true,"key":"AvMra80YZq"}],"key":"kl3aT03q6D"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Next, create the model. This gives us the two basic classes of any ABM namely the agent class (population of agent objects that doing something) and the manager class (a model object that manages the creation, activation, data collection etc of the agents).","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"eHtdUvX3bI"}],"key":"dlO0DUiNIl"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"The model can be visualized as a list containing all the agents. The model creates, holds and manages all the agent objects, specifically in a dictionary. The model activates agents in discrete time steps.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"j6AjgCgBAA"}],"key":"PyzJpIPrtq"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"A model is created as a derived class that extends ","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"PvBRKfPVnw"},{"type":"inlineCode","value":"mesa.Model","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"tck9pKPJNr"},{"type":"text","value":". Agents can be added to the model upon its creation by doing so in the ","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"rGpVj65GUS"},{"type":"inlineCode","value":"__init__()","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"wpCwu7Nbhc"},{"type":"text","value":" function. Here we instead implement specific functions for adding agents after the creation of the model.","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"JiIEYZKt4I"}],"key":"mxXCon7Ygq"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"The ","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"RTEfqG2cZc"},{"type":"inlineCode","value":"step()","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"a8VZYoiE8l"},{"type":"text","value":" method of the model class handles the time propagation carried out with the ","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"HtmNtvoooC"},{"type":"inlineCode","value":"model.agents.shuffle_do()","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"MVUy7nFH2K"},{"type":"text","value":" method. The name of the ","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"sYGeNPmEGE"},{"type":"inlineCode","value":"step()","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"LV0XCApwyd"},{"type":"text","value":" method of the model cannot be changed.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"TPwzLuFE0Q"}],"key":"fpOqETfC9H"}],"key":"lA6n7c4ELB"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"class EcoSystem(mesa.Model):\n\n    def __init__(self):\n        super().__init__()  # parent class initialization\n\n    def add_predators(self, number_predators=1):\n        Predator.create_agents(self, n=number_predators)\n\n    def add_prey(self, number_prey=1):\n        Prey.create_agents(self, n=number_prey)\n\n    def step(self):\n        print(\"model step\")\n        self.agents.shuffle_do(\"step\")","key":"GuPNHdGRz6"},{"type":"outputs","id":"p2Q7Y93_yZPlL2c6S2Tiz","children":[],"key":"HDK96wDP7F"}],"key":"YsyF95HMsn"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Time propagation","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"VAhDIuGvBo"}],"identifier":"time-propagation","label":"Time propagation","html_id":"time-propagation","implicit":true,"key":"yqRgMntTPO"}],"key":"euLv3v8LPy"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Create an instance of the model.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"H2cTTx6Pg1"}],"key":"MQ6hDUuLUt"}],"key":"gksBRoUDZQ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"my_model = EcoSystem()","key":"gx1KkyyjXA"},{"type":"outputs","id":"kbG9IdST9Hv07r1RUWRlT","children":[],"key":"QHG2PBQGc5"}],"key":"HfPvSIQlKF"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Add agents to the ABM.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"H4nk3EClcY"}],"key":"DHT0ZikaXL"}],"key":"tuN2jvjfbG"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"my_model.add_predators(1)\nmy_model.add_prey(3)","key":"A0wNXeoEEK"},{"type":"outputs","id":"SgnfHojU709lElq6AgGzL","children":[],"key":"IttAWct8Ak"}],"key":"sYlVr3Olyl"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Time propagate the ABM a certain number of discrete time steps. The ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"lOF5TAxcAX"},{"type":"inlineCode","value":"shuffle_do()","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"BbFzleOb3z"},{"type":"text","value":" function will time propagate agents in random order. This is normally what you want to do, but ordered activation is also available with the ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"WDzTANjAdg"},{"type":"inlineCode","value":"do()","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"OBDxWi0FG0"},{"type":"text","value":" function.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"AuOYcY6OSq"}],"key":"tZwu0dA6ej"}],"key":"P3s5BlHJjM"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"my_model.run_for(5)","key":"BYz6lw2Tnw"},{"type":"outputs","id":"WW-pWI447YG1EF69wRLGi","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"model step\nagent: 4, age: 1, food value: 51\nagent: 2, age: 1, food value: 51\nagent: 3, age: 1, food value: 51\nagent: 1, age: 1, strength: 90\nmodel step\nagent: 4, age: 2, food value: 52\nagent: 1, age: 2, strength: 80\nagent: 3, age: 2, food value: 52\nagent: 2, age: 2, food value: 52\nmodel step\nagent: 3, age: 3, food value: 53\nagent: 1, age: 3, strength: 70\nagent: 2, age: 3, food value: 53\nagent: 4, age: 3, food value: 53\nmodel step\nagent: 3, age: 4, food value: 54\nagent: 2, age: 4, food value: 54\nagent: 1, age: 4, strength: 60\nagent: 4, age: 4, food value: 54\nmodel step\nagent: 2, age: 5, food value: 55\nagent: 3, age: 5, food value: 55\nagent: 4, age: 5, food value: 55\nagent: 1, age: 5, strength: 50\n"},"children":[],"key":"dZmvUxlT9Y"}],"key":"jBWHGsXS07"}],"key":"OAZ2rlQ4s8"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Adding space","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"fGvGJ6csbU"}],"identifier":"adding-space","label":"Adding space","html_id":"adding-space","implicit":true,"key":"ycgpmmSjRG"}],"key":"AWWCquQAjM"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Cells form the foundation of the cell space system, enabling rich spatial environments where both location properties and agent behaviors matter. They’re useful for modeling things like varying terrain, infrastructure capacity, or environmental conditions.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"DiUV4peM1j"}],"key":"ngmussW8Bu"}],"key":"trUf6sfdvD"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Cell Agents are agents that understand how to exist in and move through cell spaces. They are specialized agent classes that handle cell occupation, movement, and proper registration.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"aMVVJgz3rB"}],"key":"oRT9FpTpWo"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"We have:","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"kfCRbd2D4d"}],"key":"SyC4SUUpZm"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"inlineCode","value":"CellAgent","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"bHKIuH8FVw"},{"type":"text","value":": Mobile agents that can move between cells","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"QbZ9jjGhqY"}],"key":"Hbxx57Zqo8"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"inlineCode","value":"FixedAgent","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"BdxiosTl3n"},{"type":"text","value":": Immobile agents permanently fixed to cells","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"jmEjqV6ymu"}],"key":"Wpu3REizUH"},{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"inlineCode","value":"Grid2DMovingAgent","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"eZ43wS1QTA"},{"type":"text","value":": Agents with grid-specific movement capabilities","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"KmwVK7jefe"}],"key":"tPJ7y2sMf4"},{"type":"paragraph","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"These classes ensure consistent agent-cell relationships and proper state management as agents move through the space. They can be used directly or as examples for creating custom cell-aware agents.","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"xvPpIe7VFc"}],"key":"pMr73pnvCl"}],"key":"L0n16nD7FK"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Moving cell agents","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"AbH1Teo3Dn"}],"identifier":"moving-cell-agents","label":"Moving cell agents","html_id":"moving-cell-agents","implicit":true,"key":"fMUaRLH8YF"}],"key":"iUxd2NAO9R"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"class MyAgent(mesa.discrete_space.CellAgent):\n\n    def __init__(self, model, cell):\n        super().__init__(model)\n\n        self.move_to(cell)  # place agent in grid\n\n    def move(self):\n\n        new_cell = self.cell.neighborhood.select_random_cell()\n        self.move_to(new_cell)\n\n        print(f\"agent: {self.unique_id}, position: {self.cell.position}\")\n\n\nclass MyModel(mesa.Model):\n\n    def __init__(self, number_agents, width, height):\n        super().__init__()\n\n        self.num_agents = number_agents\n\n        self.grid = mesa.discrete_space.OrthogonalMooreGrid(\n            (width, height),\n            torus=False,\n            random=self.random,\n        )\n\n        agents = MyAgent.create_agents(\n            self,\n            self.num_agents,\n            # Randomly select cells for agents\n            self.random.choices(self.grid.all_cells.cells, k=self.num_agents),\n        )\n\n        print(f\"model time: {self.time}\")\n        for agent in agents:\n            print(f\"agent: {agent.unique_id}, position: {agent.cell.position}\")\n\n    def step(self):\n        print(f\"model time: {self.time}\")\n        self.agents.shuffle_do(\"move\")","key":"X3x2t4UOq1"},{"type":"outputs","id":"_8zKkXWVsrROgx03_GF-j","children":[],"key":"JioC6Mz8Oj"}],"key":"Zs6HwUjYnY"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"my_model = MyModel(3, 10, 10)","key":"R2mwqbEZRL"},{"type":"outputs","id":"1wswQrv8DHPUz9XUQvlIN","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"model time: 0.0\nagent: 1, position: [5. 0.]\nagent: 2, position: [7. 3.]\nagent: 3, position: [2. 9.]\n"},"children":[],"key":"sDz1jCZLm3"}],"key":"JixN2vJJaQ"}],"key":"FpL8C5PSlp"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"my_model.run_for(5)","key":"Hk1LO5fg3S"},{"type":"outputs","id":"38KsDLgEMTLIxcXVabQ1Y","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"model time: 1.0\nagent: 2, position: [8. 2.]\nagent: 3, position: [1. 8.]\nagent: 1, position: [6. 0.]\nmodel time: 2.0\nagent: 1, position: [5. 0.]\nagent: 2, position: [9. 2.]\nagent: 3, position: [2. 8.]\nmodel time: 3.0\nagent: 1, position: [4. 0.]\nagent: 3, position: [1. 9.]\nagent: 2, position: [9. 3.]\nmodel time: 4.0\nagent: 3, position: [1. 8.]\nagent: 2, position: [9. 4.]\nagent: 1, position: [5. 1.]\nmodel time: 5.0\nagent: 1, position: [5. 0.]\nagent: 2, position: [9. 3.]\nagent: 3, position: [2. 9.]\n"},"children":[],"key":"lOgv9MNAjf"}],"key":"ogeSmJH7Xj"}],"key":"lkyQt9p5Aa"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"In this example, we have created a model with three cell agents moving in a landscape of 10x10 grid cells. In every time step, every agent move from its present cell to a neighboring cell.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"QYrEveM9Py"}],"key":"CXVHMZNF82"}],"key":"ujSkxs5fii"}],"key":"GPbKpZxiu5"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Pandas","url":"/docs/pandas","group":"Mathematical Modeling in Biotechnology"},"next":{"title":"PyTorch","url":"/docs/pytorch","group":"Mathematical Modeling in Biotechnology"}}},"domain":"http://localhost:3000"}