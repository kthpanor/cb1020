=200,\n    max_depth=2,\n    learning_rate=0.1,\n    random_state=0,\n)\n\ngb.fit(X_train, y_train)\n\ny_pred_gb = gb.predict(X_test)\nprint(sklearn.metrics.classification_report(y_test, y_pred_gb, target_names=cancer[\"target_names\"]))\n","key":"Csto7iPcFB"},{"type":"outputs","id":"Jc6Ib37ieT0VAtpACrHWQ","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"              precision    recall  f1-score   support\n\n   malignant       0.89      0.95      0.92        42\n      benign       0.97      0.93      0.95        72\n\n    accuracy                           0.94       114\n   macro avg       0.93      0.94      0.93       114\nweighted avg       0.94      0.94      0.94       114\n\n"},"children":[],"key":"jDFfazy8oq"}],"key":"jHe4tGaR7n"}],"key":"HwSrRhlXNw"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Effect of ensemble size: staged predictions","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"KjErZ46ms4"}],"identifier":"effect-of-ensemble-size-staged-predictions","label":"Effect of ensemble size: staged predictions","html_id":"effect-of-ensemble-size-staged-predictions","implicit":true,"key":"j4KGWn5Fh8"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Because boosting adds trees sequentially, ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"nvWZ99GLyW"},{"type":"inlineCode","value":"sklearn","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"f9kpXxpnxD"},{"type":"text","value":" lets us inspect the ensemble’s error after every stage using ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Ps2q39IBmu"},{"type":"inlineCode","value":"staged_predict","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"AJkjzbqbC3"},{"type":"text","value":", without refitting. This shows both the bias-reducing benefit of adding trees and the overfitting risk mentioned above: training error keeps dropping, while test error eventually flattens (and can even start creeping up) as more trees are added.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"trpEQ8fQ9M"}],"key":"fgQ5zUzpGT"}],"key":"rcZ2QM94X4"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"train_errors, test_errors = [], []\n\nfor y_pred_train, y_pred_test in zip(gb.staged_predict(X_train), gb.staged_predict(X_test)):\n    train_errors.append(1 - sklearn.metrics.accuracy_score(y_train, y_pred_train))\n    test_errors.append(1 - sklearn.metrics.accuracy_score(y_test, y_pred_test))\n\nplt.figure(figsize=(5, 4))\nplt.plot(train_errors, label=\"Training error\")\nplt.plot(test_errors, label=\"Test error\")\nplt.xlabel(\"Boosting iteration m\")\nplt.ylabel(\"Misclassification error\")\nplt.title(\"Gradient boosting: error vs. ensemble size\")\nplt.legend()\nplt.show()\n","key":"bG7Jl6GO9q"},{"type":"outputs","id":"bZ0riGflMcAv-oCUB1rNf","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"07eebe826da1f39bc37d00c5d7e9a848","path":"/build/07eebe826da1f39bc37d00c5d7e9a848.png"},"text/plain":{"content":"<Figure size 500x400 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"KkmZEtTJzv"}],"key":"MyIq9znozH"}],"key":"lirwA4Iruq"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Comparing a single tree to gradient boosting","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"DVe6NQZlMS"}],"identifier":"comparing-a-single-tree-to-gradient-boosting","label":"Comparing a single tree to gradient boosting","html_id":"comparing-a-single-tree-to-gradient-boosting","implicit":true,"key":"fXo4imOq3M"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"To highlight the effect of boosting, we also fit a single decision tree of comparable depth and compare test accuracy.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"ZFTnREKWbx"}],"key":"Z7a1QcbT45"}],"key":"wfD2sPihsd"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"tree = sklearn.tree.DecisionTreeClassifier(max_depth=3, random_state=0)\ntree.fit(X_train, y_train)\n\nmodels = {\n    \"Decision tree\": tree,\n    \"Gradient boosting\": gb,\n}\naccuracies = {name: sklearn.metrics.accuracy_score(y_test, m.predict(X_test)) for name, m in models.items()}\n\nplt.figure(figsize=(5, 4))\nplt.bar(accuracies.keys(), accuracies.values(), color=[\"gray\", \"tab:orange\"])\nplt.ylabel(\"Test accuracy\")\nplt.ylim(0.8, 1.0)\nplt.title(\"Single tree vs. gradient boosting\")\nplt.show()\n","key":"Qp1e7Vmy0j"},{"type":"outputs","id":"-mbWTk7gDL8cUkkjnfJSF","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"708c2f8936b6a10f4effaea29d4fe704","path":"/build/708c2f8936b6a10f4effaea29d4fe704.png"},"text/plain":{"content":"<Figure size 500x400 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"P500qRp5aR"}],"key":"T7KICnrAFk"}],"key":"mbrQm6JfCl"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Model evaluation","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"YZZH25lMYq"}],"identifier":"model-evaluation","label":"Model evaluation","html_id":"model-evaluation","implicit":true,"key":"t25zahllwV"}],"key":"ffa6hdrk3M"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"cm = sklearn.metrics.confusion_matrix(y_test, y_pred_gb)\ndisp = sklearn.metrics.ConfusionMatrixDisplay(confusion_matrix=cm, display_labels=cancer[\"target_names\"])\ndisp.plot(cmap=plt.cm.Blues)\nplt.title(\"Gradient boosting confusion matrix\")\nplt.show()\n","key":"m2L1gxE253"},{"type":"outputs","id":"ZrU8K0MFSyTWzJ-B-PBaX","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"b2d3f3f0c0071521a35c1681891cf720","path":"/build/b2d3f3f0c0071521a35c1681891cf720.png"},"text/plain":{"content":"<Figure size 640x480 with 2 Axes>","content_type":"text/plain"}}},"children":[],"key":"iCOsbQ3PKF"}],"key":"F9YsC1aalY"}],"key":"noEA2Kpj3n"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Feature importance","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"XggOGY4wHL"}],"identifier":"feature-importance","label":"Feature importance","html_id":"feature-importance","implicit":true,"key":"xkqUAEjycv"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"As with a single tree, the ensemble provides an aggregated feature importance, averaged over all 200 trees.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"pmCpqzTWKV"}],"key":"Q0xEUMeZWr"}],"key":"FDCW12Gq1g"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"importances = gb.feature_importances_\norder = importances.argsort()[::-1][:8]\n\nplt.figure(figsize=(6, 4))\nplt.barh(\n    [cancer[\"feature_names\"][i] for i in order][::-1],\n    importances[order][::-1],\n)\nplt.xlabel(\"Importance\")\nplt.title(\"Gradient boosting: top feature importances\")\nplt.tight_layout()\nplt.show()\n","key":"ppfaISXHsh"},{"type":"outputs","id":"O7YsbhZFAOop2xYF6rbHz","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"ff64f21c2043e53dc7b0bd297e6d660d","path":"/build/ff64f21c2043e53dc7b0bd297e6d660d.png"},"text/plain":{"content":"<Figure size 600x400 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"aKtPNRJADG"}],"key":"YKInhVDRrv"}],"key":"bJAA0xfjLd"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Take-away","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"lo14MIdAzB"}],"identifier":"take-away","label":"Take-away","html_id":"take-away","implicit":true,"key":"nLeMQh8yNw"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Gradient boosting (and optimized implementations such as XGBoost or LightGBM) tends to achieve the best raw predictive performance on tabular data among tree-based methods, at the cost of more careful tuning of ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"tiWO36vLfJ"},{"type":"inlineCode","value":"n_estimators","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"B8iBxe1KZ8"},{"type":"text","value":", ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"MbpWwctrpb"},{"type":"inlineCode","value":"max_depth","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"gcuj8CwiGr"},{"type":"text","value":", and ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"GKKQ95ZYY7"},{"type":"inlineCode","value":"learning_rate","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"uwQzWgmrxE"},{"type":"text","value":" to avoid overfitting — unlike a random forest (companion notebook), simply adding more trees is not always safe. In practice it is common to start with a random forest as a robust baseline and move to gradient boosting once there is time and validation data available to tune it properly.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"lLvRrU4fiZ"}],"key":"j7JGrEpdD3"}],"key":"bvWFp1Q1id"}],"key":"aVQq5m5EQM"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Random forests","url":"/docs/random-forest","group":"Mathematical Modeling in Biotechnology"},"next":{"title":"Unsupervised learning","url":"/docs/unsupervised-learning","group":"Mathematical Modeling in Biotechnology"}}},"domain":"http://localhost:3000"}