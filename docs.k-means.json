"line":3,"column":1}},"key":"s5fJh25ELH"},{"type":"strong","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"adjusted Rand index","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"QM4Ghn9Gww"}],"key":"rLzjW2soGI"},{"type":"text","value":" (ARI) measures agreement with the true cultivar labels and is included here because we happen to have them; in a real unsupervised setting only the silhouette score would be available.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"md6OyU6suZ"}],"key":"JNROyOFY2O"}],"key":"UKqJB32Jky"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"sil = sklearn.metrics.silhouette_score(X_scaled, labels)\nari = sklearn.metrics.adjusted_rand_score(y_true, labels)\nprint(f\"Silhouette score : {sil:.3f}\")\nprint(f\"Adjusted Rand index (vs. cultivar labels): {ari:.3f}\")\n","key":"tk7xcuk42f"},{"type":"outputs","id":"GRWZUORLrfsr27q4elvg7","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Silhouette score : 0.285\nAdjusted Rand index (vs. cultivar labels): 0.897\n"},"children":[],"key":"plM5oYWdyf"}],"key":"fsHjyBaHF8"}],"key":"JoBRJHPxtH"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Visualize in PCA space","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"TmxqoyWrGq"}],"identifier":"visualize-in-pca-space","label":"Visualize in PCA space","html_id":"visualize-in-pca-space","implicit":true,"key":"TSIz7EPUgq"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"We project the data onto the first two principal components (from the PCA notebook) to visualize the cluster assignments in 2D.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"T8e3wwp1Sj"}],"key":"p0cpOw7oFL"}],"key":"rdCER5nHJW"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"pca = sklearn.decomposition.PCA(n_components=2)\nX_2d = pca.fit_transform(X_scaled)\n\nfig, axes = plt.subplots(1, 2, figsize=(10, 4))\n# K-means assignments\naxes[0].scatter(X_2d[:, 0], X_2d[:, 1], c=labels, cmap=\"tab10\", s=30)\ncentroids_2d = pca.transform(kmeans.cluster_centers_)\naxes[0].scatter(centroids_2d[:, 0], centroids_2d[:, 1],\n                marker=\"X\", s=200, color=\"black\", label=\"centroids\")\naxes[0].set_title(\"K-means clusters\"); axes[0].legend()\n# True cultivar labels\nsc = axes[1].scatter(X_2d[:, 0], X_2d[:, 1], c=y_true, cmap=\"tab10\", s=30)\nfor label, name in enumerate(wine.target_names):\n    axes[1].scatter([], [], color=sc.cmap(sc.norm(label)), label=name)\naxes[1].set_title(\"True cultivar labels\"); axes[1].legend()\nfor ax in axes:\n    ax.set_xlabel(\"PC 1\"); ax.set_ylabel(\"PC 2\")\nplt.suptitle(\"K-means vs. ground truth (projected onto first two PCs)\")\nplt.tight_layout()\nplt.show()\n","key":"NaNl0pV6Uu"},{"type":"outputs","id":"dfM1jmyX7kyYjtBKgoqw1","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"4cf5cf6459caf5f01ccee3e93c7eda43","path":"/build/4cf5cf6459caf5f01ccee3e93c7eda43.png"},"text/plain":{"content":"<Figure size 1000x400 with 2 Axes>","content_type":"text/plain"}}},"children":[],"key":"nISwBNo7El"}],"key":"u8f05NZW0R"}],"key":"qpPbI2elxP"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Cross-validation and model selection","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"WvbC091aPQ"}],"identifier":"cross-validation-and-model-selection","label":"Cross-validation and model selection","html_id":"cross-validation-and-model-selection","implicit":true,"key":"c407AHMUaw"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"inlineMath","value":"K","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>K</mi></mrow><annotation encoding=\"application/x-tex\">K</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.6833em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.07153em;\">K</span></span></span></span>","key":"ibMeCdSkNW"},{"type":"text","value":" is the main hyperparameter to tune. In the absence of ground-truth labels the silhouette score is the standard criterion: fit K-means for several values of ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"haU4UewE5G"},{"type":"inlineMath","value":"K","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>K</mi></mrow><annotation encoding=\"application/x-tex\">K</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.6833em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.07153em;\">K</span></span></span></span>","key":"psvjohn7ly"},{"type":"text","value":" and choose the one that maximizes it. For larger data sets ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"WTdVOf8B5y"},{"type":"inlineCode","value":"sklearn.model_selection.KFold","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"QMn6RCK