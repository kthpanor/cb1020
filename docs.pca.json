code","children":[{"type":"code","lang":"python","executable":true,"value":"scaler = sklearn.preprocessing.StandardScaler()\nX_scaled = scaler.fit_transform(X)\n","key":"qPj8RvElaz"},{"type":"outputs","id":"S1IjKuXvPPeFWwl7LsaBu","children":[],"key":"rwmoef3mZu"}],"key":"XDOh0YuUZN"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Model definition and training","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"nwpRyFS1MQ"}],"identifier":"model-definition-and-training","label":"Model definition and training","html_id":"model-definition-and-training","implicit":true,"key":"M0dDMqfG2O"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"We fit PCA retaining all 13 components first, to inspect the explained variance, Eq. (2).","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"AK1CC9Ppb2"}],"key":"hXukVQYbDS"}],"key":"W6ufwKPfIw"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"pca_full = sklearn.decomposition.PCA()\npca_full.fit(X_scaled)\n\nexplained = pca_full.explained_variance_ratio_\ncumulative = np.cumsum(explained)\n\nplt.figure(figsize=(6, 4))\nplt.bar(range(1, len(explained) + 1), explained, label=\"per component\", color=\"tab:blue\", alpha=0.7)\nplt.plot(range(1, len(cumulative) + 1), cumulative, \"o-\", color=\"tab:orange\", label=\"cumulative\")\nplt.axhline(0.90, color=\"gray\", linestyle=\"--\", label=\"90% variance\")\nplt.xlabel(\"Principal component\"); plt.ylabel(\"Explained variance ratio\")\nplt.legend(); plt.title(\"Scree plot – wine data\")\nplt.show()\n","key":"pSR8GvuToa"},{"type":"outputs","id":"O9BFrVRAMHGhS6L3-_UMZ","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"ima