e,"protocol":"wiki","key":"X7AKvKURdm"}],"key":"cSszk3vqft"}],"key":"e5Oov3Zz55"},{"type":"listItem","spread":true,"position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"paragraph","children":[{"type":"link","url":"https://en.wikipedia.org/wiki/K-nearest_neighbors_algorithm","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"K-Nearest Neighbors (KNN)","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"bzADgloHFy"}],"urlSource":"https://en.wikipedia.org/wiki/K-nearest_neighbors_algorithm","data":{"page":"K-nearest_neighbors_algorithm","wiki":"https://en.wikipedia.org/","lang":"en"},"internal":false,"protocol":"wiki","key":"Bro2GqxA9l"}],"key":"fS5X6P2iaU"}],"key":"QUXzuYiJXI"}],"key":"qVb0zfHMq7"}],"key":"jvNt6YzyHa"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Example: Recognition of handwritten numbers","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"zwZxDAMBrt"}],"identifier":"example-recognition-of-handwritten-numbers","label":"Example: Recognition of handwritten numbers","html_id":"example-recognition-of-handwritten-numbers","implicit":true,"key":"h0pKZUOUXl"}],"key":"jJm0U3GMfY"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"This tutorial uses ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"nVUkA4FZs3"},{"type":"link","url":"https://scikit-learn.org/stable/","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"scikit-learn","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"mkEHh2TEJI"}],"urlSource":"https://scikit-learn.org/stable/","key":"pvLovIydXn"},{"type":"text","value":" (or sklearn), an open source machine learning (ML) framework based on numpy, scipy and matplotlib.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"cmdVwXFiSG"}],"key":"ESRGcFKtXy"}],"key":"stdj7t0xed"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import matplotlib.pyplot as plt\n\n# Import datasets, classifiers and performance metrics\nfrom sklearn import datasets, metrics, svm\nfrom sklearn.model_selection import train_test_split","key":"xUlYDdCIrW"},{"type":"outputs","id":"wqxnb51_zH1ElAFyfwziy","children":[],"key":"X0ef0u6Yyl"}],"key":"IURjjHwc5L"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"A widely used example for the use of machine learning is the recognition of handwritten numbers, for which we will build, train and assess the accuracy of a machine learning model. The example is so common in fact that sklearn, like many other ML frameworks, come with a built-in data set of handwritten numbers.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"xiLU5OtNah"}],"key":"flzBD24xBf"}],"key":"R6Gpp7iyvP"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Loading a data set containing 1797 8 x 8 images of digits\ndigits = datasets.load_digits()\n\nprint(type(digits.images))\nprint(digits.images.shape)","key":"cI3m6u7heS"},{"type":"outputs","id":"__0QqEhxQVGMBK5atKmG3","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"<class 'numpy.ndarray'>\n(1797, 8, 8)\n"},"children":[],"key":"IycEIw4qxV"}],"key":"fwWUf8ghmd"}],"key":"fhbPZrsr7U"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig, axes = plt.subplots(nrows=3, ncols=5, figsize=(10, 7))\nfor i, row in enumerate(axes):\n    for j, ax in enumerate(row):\n        ax.set_axis_off()\n        ax.imshow(\n            digits.images[i * 10 + j], cmap=plt.cm.gray_r, interpolation=\"nearest\"\n        )\n        ax.set_title(f\"Ground truth: {digits.target[i * 10 + j]}\")","key":"e4dyiTLd1m"},{"type":"outputs","id":"lKiKtEGh4QVlRq5JcsidQ","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"1eef9b1e7fc908710b81d98c209a4f7c","path":"/build/1eef9b1e7fc908710b81d98c209a4f7c.png"},"text/plain":{"content":"<Figure size 1000x700 with 15 Axes>","content_type":"text/plain"}}},"children":[],"key":"LF7qOwnsnk"}],"key":"YUakkSqu5C"}],"key":"roZgYXQQln"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Splitting the dataset","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"KStTPxLRSG"}],"identifier":"splitting-the-dataset","label":"Splitting the dataset","html_id":"splitting-the-dataset","implicit":true,"key":"tlmwYjUWvb"}],"key":"Pa0grj2HjP"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"For ML applications the data is always split in at least two datasets, since for proper evaluation of the performance of the trained model unseen data is required. Whether additional separation of the data set is required depends on the ML model applied, as well as the optimization algorithm.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"bkY73IuCwL"}],"key":"kx9wtrFDU0"}],"key":"DORDfu0b95"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Flatten the images\nn_samples = len(digits.images)\ndata = digits.images.reshape((n_samples, -1))\n\n# Split data into 80% train and 20% test subsets, which is a standard ratio\nX_train, X_test, y_train, y_test = train_test_split(\n    data, digits.target, test_size=0.2, shuffle=True\n)","key":"VV6BAoKVDf"},{"type":"outputs","id":"V5Db5OGaFj_bGplSIPHyp","children":[],"key":"bQVn1AtS5G"}],"key":"ma7EcdOT7Y"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Pick the model","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ip8Xa36mES"}],"identifier":"pick-the-model","label":"Pick the model","html_id":"pick-the-model","implicit":true,"key":"ShimjhYKbv"}],"key":"rPAzR42GqC"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"With a rather modest amount of annotated data at hand to solve a classification type problem, it makes sense to use an SVM, since they can make use of different kernels, projecting lower dimensional parameter spaces into higher dimensional ones and therefore saving a lot on the parameters to fit. NNs are more flexible in their basic form, which comes with the price of more parameters.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"TOklxDtObt"}],"key":"ryBeQHkyr6"}],"key":"OwUzf4npM2"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Create SVM classifier with a radial basis function (RBF) kernel\nmy_classifier = svm.SVC(gamma=0.001)","key":"IHmG98USnV"},{"type":"outputs","id":"u9TEWntQfBaGtsjrv4r-a","children":[],"key":"mmeaCeuq3P"}],"key":"H3H7JS4d7Z"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Train the model","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"jfb0Fd5EPb"}],"identifier":"train-the-model","label":"Train the model","html_id":"train-the-model","implicit":true,"key":"IIRG71N3Zd"}],"key":"ikAFDPrNcs"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Train the model on the train subset\nmy_classifier.fit(X_train, y_train)\n\n# Remember to save your model to a file, if you want to use it again!!!\n# This can be achieved e.g. by pickling my_classifier\n# import pickle\n\n# save\n# with open('my_model.pkl','wb') as f:\n#    pickle.dump(my_classifier,f)\n\n# load\n# with open('my_model.pkl', 'rb') as f:\n#    my_classifier = pickle.load(f)","key":"uQ7MWvJHuZ"},{"type":"outputs","id":"wWIWTjU54fuN6ZvAJnvwa","children":[{"type":"output","jupyter_data":{"output_type":"execute_result","execution_count":10,"metadata":{},"data":{"text/html":{"content_type":"text/html","hash":"f0dd5b14833fc3bfd4596e142bc755d9","path":"/build/f0dd5b14833fc3bfd4596e142bc755d9.html"},"text/plain":{"content":"SVC(gamma=0.001)","content_type":"text/plain"}}},"children":[],"key":"segNaVmNQg"}],"key":"o28QL1Hl3D"}],"key":"A2NMvFz7jX"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Assess the accuracy","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"fc5wAvFTOv"}],"identifier":"assess-the-accuracy","label":"Assess the accuracy","html_id":"assess-the-accuracy","implicit":true,"key":"uwPSWy0YaZ"}],"key":"kpvgjlrGSu"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Predict the value of the digit on the test subset\npredicted = my_classifier.predict(X_test)\n\n# Plot some predictions\nfig, axes = plt.subplots(nrows=1, ncols=6, figsize=(13, 3))\nfor ax, image, prediction, GroundTruth in zip(axes, X_test, predicted, y_test):\n    ax.set_axis_off()\n    image = image.reshape(8, 8)\n    ax.imshow(image, cmap=plt.cm.gray_r, interpolation=\"nearest\")\n    ax.set_title(f\"Prediction: {prediction} \\nGround truth: {GroundTruth}\")","key":"xwBMp3tQP8"},{"type":"outputs","id":"1mZb2vwcSzQNmCqvax1sR","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"45e97af6d650db271bce6627f98438f4","path":"/build/45e97af6d650db271bce6627f98438f4.png"},"text/plain":{"content":"<Figure size 1300x300 with 6 Axes>","content_type":"text/plain"}}},"children":[],"key":"pGPxeVtHNo"}],"key":"DTbJ0iWSsP"}],"key":"jkgscpAVCi"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Show how the classifier performs for the individual numbers\nprint(\n    f\"Classification report for classifier {my_classifier}:\\n\"\n    f\"{metrics.classification_report(y_test, predicted)}\\n\"\n)","key":"Jb2qnSr5Cs"},{"type":"outputs","id":"WGR4ycfHSJlPEtlCcv_lB","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Classification report for classifier SVC(gamma=0.001):\n              precision    recall  f1-score   support\n\n           0       1.00      1.00      1.00        41\n           1       0.94      1.00      0.97        30\n           2       1.00      1.00      1.00        34\n           3       1.00      1.00      1.00        38\n           4       1.00      0.95      0.97        38\n           5       0.97      1.00      0.99        33\n           6       1.00      1.00      1.00        39\n           7       1.00      1.00      1.00        37\n           8       0.97      0.94      0.96        36\n           9       0.97      0.97      0.97        34\n\n    accuracy                           0.99       360\n   macro avg       0.99      0.99      0.99       360\nweighted avg       0.99      0.99      0.99       360\n\n\n"},"children":[],"key":"HVh1BcMLh1"}],"key":"NjoLXUqZDW"}],"key":"jQBycbxDBb"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Show confusion matrix\ndisp = metrics.ConfusionMatrixDisplay.from_predictions(y_test, predicted)\ndisp.figure_.suptitle(\"Confusion Matrix\")\n# uncomment to show it as 2D array\n# print(f\"Confusion matrix:\\n{disp.confusion_matrix}\")\n\nplt.show()","key":"sq08mLhb8R"},{"type":"outputs","id":"322X9FLlTJq8JqcVS9atg","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"8a8b7128291cf6cf0fbf70cc860958d1","path":"/build/8a8b7128291cf6cf0fbf70cc860958d1.png"},"text/plain":{"content":"<Figure size 640x480 with 2 Axes>","content_type":"text/plain"}}},"children":[],"key":"qC0fNYxalu"}],"key":"rvs5wF1a1Y"}],"key":"OKFrZPhZd8"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# amount of coefficients to be fitted for the SVM used here\n# 45 * 8 * 8 + 45\nprint(\n    f\"The amount of coefficients used by the SVM model are \"\n    f\"{np.prod(my_classifier._get_coef().shape) + len(my_classifier.intercept_)}\"\n)\n\n# amount of coefficients to be fitted for the NN from the previous notebook\n# bias of first layer 28 * 28, hidden layer 512, and output layer 10\n# connections 28 * 28 * 512 + 512 * 10\nprint(\n    f\"The amount of coefficients used by the NN model of the previous \"\n    f\"notebook are {28 * 28 + 512 + 10 + 28 * 28 * 512 + 512 * 10}\"\n)\n# adapted to the problem at hand with 8 x 8 images\nprint(\n    f\"The amount of coefficients used by an NN model for this problem inspired \"\n    f\"by the previous notebook are {8 * 8 + 512 + 10 + 8 * 8 * 512 + 512 * 10}\"\n)","key":"siOjZcFcIf"},{"type":"outputs","id":"4zSilHUzjombM3x8OEoHR","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"The amount of coefficients used by the SVM model are 2925\nThe amount of coefficients used by the NN model of the previous notebook are 407834\nThe amount of coefficients used by an NN model for this problem inspired by the previous notebook are 38474\n"},"children":[],"key":"PMmTsTFLQ4"}],"key":"kPHnTXSTlu"}],"key":"wTca46JolP"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# build a NN with similar amount of parameters than SVM and compare performance\nfrom sklearn.neural_network import MLPClassifier\n\nmy_nn_classifier = MLPClassifier(hidden_layer_sizes=(45))\nmy_nn_classifier.fit(X_train, y_train)\nmy_nn_prediction = my_nn_classifier.predict(X_test)\n\nprint(\n    f\"The SVM has an accuracy of {metrics.accuracy_score(y_test, predicted)}, \"\n    f\"while the NN has an accuracy of {metrics.accuracy_score(y_test, my_nn_prediction)}\"\n)\n\nnn_disp = metrics.ConfusionMatrixDisplay.from_predictions(y_test, my_nn_prediction)\nnn_disp.figure_.suptitle(\"Confusion Matrix\")\nplt.show()","key":"TPqPZeBKZo"},{"type":"outputs","id":"jUg8jW6nk96vdho8kbOsS","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"The SVM has an accuracy of 0.9861111111111112, while the NN has an accuracy of 0.9611111111111111\n"},"children":[],"key":"FmkReYuODi"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"bc858029a2e223545a8f3b52c6c6fc6d","path":"/build/bc858029a2e223545a8f3b52c6c6fc6d.png"},"text/plain":{"content":"<Figure size 640x480 with 2 Axes>","content_type":"text/plain"}}},"children":[],"key":"dQFfqOrKNn"}],"key":"hnCoKrTUzu"}],"key":"hg78ysP9e5"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"As can be seen the overall accuracy is very good, with the confusion matrix showing which numbers have been confused with each other how often.\nIt is also interesting to see how the model performance improved over the training iterations, so-called epochs.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"gK9wbyQOoD"}],"key":"e6xPUIVxqg"}],"key":"ZN3FeLfhiv"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"MaxIters = np.array([0, 1, 2, 5, 10, 20, 50, 100, 200])\naccuracies = []\n\nfor it in MaxIters:\n    my_classifier = svm.SVC(gamma=0.001, max_iter=it)\n    my_classifier.fit(X_train, y_train)\n    predicted = my_classifier.predict(X_test)\n    acc = metrics.accuracy_score(y_test, predicted)\n    accuracies.append(acc)\n\nprint(\"max_epoch\", \"accuracy\")\nfor mi, ac in zip(MaxIters, accuracies):\n    print(mi, ac)\n\nfig, axes = plt.subplots(nrows=1, ncols=2, figsize=(12, 5))\naxes[0].set_title(\"first iterations\")\naxes[1].set_title(\"until convergence\")\naxes[0].plot(MaxIters[:4], accuracies[:4])\naxes[1].plot(np.log10(MaxIters[1:]), accuracies[1:])\naxes[0].set_xlabel(\"Number of epochs\")\naxes[1].set_xlabel(\"log(Number of epochs)\")\naxes[0].set_ylim(0, 1)\nfor ax in axes:\n    ax.set_ylabel(\"Accuracy with respect to the test set\")","key":"YAs3CSQn5Q"},{"type":"outputs","id":"_Y58WdgNXDAMsiT8bEKz2","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"max_epoch accuracy\n0 0.09444444444444444\n1 0.6361111111111111\n2 0.8333333333333334\n5 0.9222222222222223\n10 0.9833333333333333\n20 0.9916666666666667\n50 0.9861111111111112\n100 0.9861111111111112\n200 0.9861111111111112\n"},"children":[],"key":"Rq2VysEPZt"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"708e181baa1a20ed6a78f52cba3ac5a7","path":"/build/708e181baa1a20ed6a78f52cba3ac5a7.png"},"text/plain":{"content":"<Figure size 1200x500 with 2 Axes>","content_type":"text/plain"}}},"children":[],"key":"zAUe8FpmYc"}],"key":"bRZ5ESj52u"}],"key":"e1ShVolIjK"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"One can also investigate how the performance differs when using more or less data.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"v55nEyJvv6"}],"key":"rjRWbAwjBo"}],"key":"x7fwsArdEQ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from sklearn.model_selection import LearningCurveDisplay, ShuffleSplit\n\n# start from untrained model again\nmy_classifier = svm.SVC(kernel=\"rbf\", gamma=0.001)\n\ncommon_params = {\n    \"X\": np.concatenate((X_train, X_test), axis=0),\n    \"y\": np.concatenate((y_train, y_test), axis=0),\n    \"train_sizes\": np.linspace(0.1, 1.0, 5),\n    \"cv\": ShuffleSplit(n_splits=50, test_size=0.2, random_state=0),\n    \"score_type\": \"both\",\n    \"n_jobs\": 4,\n    \"line_kw\": {\"marker\": \"o\"},\n    \"std_display_style\": \"fill_between\",\n    \"score_name\": \"Accuracy\",\n}\n\nfig, ax = plt.subplots(nrows=1, ncols=1, figsize=(10, 6), sharey=True)\nLearningCurveDisplay.from_estimator(my_classifier, **common_params, ax=ax)\nhandles, label = ax.get_legend_handles_labels()\nax.legend(handles[:2], [\"Training Score\", \"Test Score\"])\nax.set_title(f\"Learning Curve for {my_classifier.__class__.__name__}\")","key":"dIZEy8OYvj"},{"type":"outputs","id":"Na_vRanZEOnG2k-0FlY-w","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"30676f2429d6ec60bbc71b41b2877123","path":"/build/30676f2429d6ec60bbc71b41b2877123.png"},"text/plain":{"content":"<Figure size 1000x600 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"sJrCUIzsho"}],"key":"eaJEYcDnpu"}],"key":"LbbxpfhNpx"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Comparison between classifier models","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"tppGea3gfX"}],"identifier":"comparison-between-classifier-models","label":"Comparison between classifier models","html_id":"comparison-between-classifier-models","implicit":true,"key":"ZTUdvmcKaa"}],"key":"u4a7FxqRG9"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Now one can start comparing the performance between different models, as e.g. done here with a naive Bayes classifier:","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"AGB9dlkpNY"}],"key":"tpUkbL5lek"}],"key":"itK1hNWzNQ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from sklearn.naive_bayes import GaussianNB\n\nnaive_bayes = GaussianNB()\n\nfig, ax = plt.subplots(nrows=1, ncols=2, figsize=(10, 6), sharey=True)\n\nfor ax_idx, estimator in enumerate([naive_bayes, my_classifier]):\n    LearningCurveDisplay.from_estimator(estimator, **common_params, ax=ax[ax_idx])\n    handles, label = ax[ax_idx].get_legend_handles_labels()\n    ax[ax_idx].legend(handles[:2], [\"Training Score\", \"Test Score\"])\n    ax[ax_idx].set_title(f\"Learning Curve for {estimator.__class__.__name__}\")","key":"m2F3DGasKX"},{"type":"outputs","id":"z8ynEjcWT0JO470xrS1EN","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"c9f5b04de455dfdfc4a9bd0b69a5a2ff","path":"/build/c9f5b04de455dfdfc4a9bd0b69a5a2ff.png"},"text/plain":{"content":"<Figure size 1000x600 with 2 Axes>","content_type":"text/plain"}}},"children":[],"key":"R3V6VlOYUT"}],"key":"fPuSQ0dwap"}],"key":"Tkqw8dzBpH"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Additional material","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"C6SePeLgqx"}],"identifier":"additional-material","label":"Additional material","html_id":"additional-material","implicit":true,"key":"BJkCC2nydq"}],"key":"gx8hJPgudS"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"In order to make an educated decision on which model to pick, you should read through additional material, starting with ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"P5v5ShUSEw"},{"type":"link","url":"https://www.coursera.org/articles/machine-learning-algorithms","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"very short summaries","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"X77aoulbCn"}],"urlSource":"https://www.coursera.org/articles/machine-learning-algorithms","key":"ynTXvdqXsJ"},{"type":"text","value":". YouTube also offers comprehensive introductions, like the one from scikit-learn itself.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"EOBcA0gpTH"}],"key":"x9aBh0yAtF"}],"key":"NQpews325X"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from IPython.display import YouTubeVideo\n\nYouTubeVideo(\"playlist?list=PL2okA_2qDJ-m44KooOI7x8tu85wr4ez4f\")","key":"U0AcISTdWV"},{"type":"outputs","id":"uo18m0oSVNr8r7AqDlHqE","children":[{"type":"output","jupyter_data":{"output_type":"execute_result","execution_