position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"rqzMBJpo5U"}],"key":"sC5HP6WKxV"}],"key":"AVYABC7eDu"}],"key":"tNyaPc2XPI"}],"key":"FzygnpfXqr"},{"type":"block","kind":"notebook-content","children":[{"type":"image","url":"/build/b83641ccecb25255bb112f2d13e4c117.png","alt":"Screenshot 2026-06-23 at 13.36.44.png","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"fOFXKEWQTo","urlSource":"data:image/png;base64,iVBORw0KGg...5ErkJggg=="}],"key":"co3o5mrcfY"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Implmenting the model","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"XR7iE7WGGB"}],"identifier":"implmenting-the-model","label":"Implmenting the model","html_id":"implmenting-the-model","implicit":true,"key":"MFEFFy2Fpy"}],"key":"wsT2P25Rin"},{"type":"block","kind":"notebook-content","data":{"slideshow":{"slide_type":"subslide"}},"children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"CellAgent","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"qBTvZwAbsz"}],"identifier":"cellagent","label":"CellAgent","html_id":"cellagent","implicit":true,"key":"MaAL7YKe3Z"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Every agent starts with a wealth of 1. If an agent has nonzero wealth and enters into a non-empty cell, the agent will give one unit of wealth to a random cellmate.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"xkPheJ06bL"}],"key":"VM4RAJ78vI"}],"key":"h5CCYsis2S"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"class MoneyAgent(mesa.discrete_space.CellAgent):\n\n    def __init__(self, model, cell):\n        super().__init__(model)\n\n        self.move_to(cell)  # place agent in grid\n\n        self.wealth = 1\n\n    def move(self):\n\n        new_cell = self.cell.neighborhood.select_random_cell()\n        self.move_to(new_cell)\n\n        cellmates = [a for a in self.cell.agents if a is not self]\n\n        if self.wealth > 0 and len(cellmates) > 0:\n            other_agent = self.random.choice(cellmates)\n            other_agent.wealth += 1\n            self.wealth -= 1","key":"sQhRsA8B21"},{"type":"outputs","id":"UTQcpH7otdoP9ZlW-ZkwE","children":[],"key":"Ctk5oMuDZb"}],"key":"NVfcaXIeuW"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Model","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"onDeB3V9o1"}],"identifier":"model","label":"Model","html_id":"model","implicit":true,"key":"gQbpmGhWFU"},{"type":"paragraph","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"Create a model that defines a data collector that in each time step records the wealth of agents and the overall indicator for wealth distribution.","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"G3FmYFTOVl"}],"key":"WKjk17UkgJ"}],"key":"vJyCNMJ5GZ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"class MoneyModel(mesa.Model):\n\n    def __init__(self, number_agents, width, height):\n        super().__init__()  # parent class initialization\n\n        self.grid = mesa.discrete_space.OrthogonalMooreGrid(\n            (width, height), torus=False, random=self.random\n        )\n\n        MoneyAgent.create_agents(\n            self,\n            number_agents,\n            # Randomly select cells for agents\n            self.random.choices(self.grid.all_cells.cells, k=number_agents),\n        )\n\n        self.datacollector = mesa.DataCollector(\n            model_reporters={\"Gini coefficient\": lambda m: m.compute_gini()},\n            agent_reporters={\n                \"Wealth\": \"wealth\",\n                \"Agent position\": lambda a: a.cell.position,\n            },\n        )\n\n    def compute_gini(self):\n\n        N = len(self.agents)\n\n        # collect wealth of agents into a list and sort it in increasing order\n        agent_wealths = [agent.wealth for agent in self.agents]\n\n        x = sorted(agent_wealths)\n        X = sum(x)\n\n        if X == 0:\n            return 0\n\n        # calculate the Gini coefficient\n        B = sum(xi * (N + 1 - i) for i, xi in enumerate(x, start=1))\n        G = (N + 1 - 2 * B / X) / N\n\n        return G\n\n    def step(self):\n        self.datacollector.collect(self)\n        self.agents.shuffle_do(\"move\")","key":"PtCLRVeivk"},{"type":"outputs","id":"HAROHXkTEb1uA-CSNLEqy","children":[],"key":"ehwG56GI0C"}],"key":"cbvRndEGx6"},{"type":"block","kind":"notebook-content","data":{"slideshow":{"slide_type":"subslide"}},"children":[{"type":"heading","depth":4,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Reporter","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"qSyyYOasI9"}],"identifier":"reporter","label":"Reporter","html_id":"reporter","implicit":true,"key":"p71nraCIXv"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"As metric indicator of wealth distribution, we have here implemented the ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"A0kqNjRYcA"},{"type":"link","url":"https://en.wikipedia.org/wiki/Gini_coefficient","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Gini coefficient","position":{"sta